{
  "name": "local-agent-gateway",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26 <27"
  },
  "packageManager": "pnpm@11.13.0",
  "volta": {
    "node": "26.3.1",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "local:install": "tsx scripts/local-production.ts install",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint src tests scripts",
    "test": "vitest run --maxWorkers=4",
    "smoke": "tsx scripts/smoke.ts",
    "verify": "node --run lint && node --run typecheck && node --run test && node --run build"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.10.0",
    "kysely": "^0.29.3",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "openai": "^6.48.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
