NODE_ENV=development
PORT=8787
HOST=127.0.0.1

DATABASE_PATH=./data/local-agent-gateway.sqlite

APP_BACKEND=codex-app-server
CODEX_APP_SERVER_COMMAND=codex
# Optional: pin the model passed to `codex app-server -c model=...`.
# CODEX_APP_SERVER_MODEL=gpt-5.4-mini
CODEX_APP_SERVER_TURN_TIMEOUT_MS=600000
CODEXGW_MAX_PARALLEL_READ_TASKS=4

# JSON array of repos this gateway may operate on. Replace paths locally.
# Example:
# CODEXGW_ALLOWED_REPOS_JSON=[{"id":"local-agent-gateway","path":"/absolute/path/to/local-agent-gateway","defaultMode":"read-only","allowedModes":["read-only","workspace-write"]}]
CODEXGW_ALLOWED_REPOS_JSON=

# token hash pepper. Use a long random value in real deployments.
TOKEN_PEPPER=change-me-to-a-long-random-secret

# Temporary value for creating the first admin token. Remove after bootstrap.
# Refused in production; use only for local bootstrap, then delete it.
BOOTSTRAP_ADMIN_TOKEN=
