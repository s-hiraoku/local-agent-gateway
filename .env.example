CODEXGW_HOST=127.0.0.1
CODEXGW_PORT=8787
CODEXGW_DATABASE_PATH=./data/gateway-v2.sqlite

# Required. Inject real values through a local secret manager; do not commit them.
CODEXGW_API_TOKEN=
CODEXGW_DATA_ENCRYPTION_KEY=

# Required server-side repository registry. Clients can use only the public IDs.
# CODEXGW_REPOSITORIES_JSON=[{"id":"local-agent-gateway","path":"/absolute/path/to/local-agent-gateway"}]
CODEXGW_REPOSITORIES_JSON=

# Use a dedicated Codex home and authenticate it before starting the Gateway.
CODEXGW_CODEX_COMMAND=codex
# CODEXGW_CODEX_HOME=/absolute/path/to/.codex-gateway
# CODEXGW_CODEX_MODEL=
# Disabled by default. When true, enables the loopback-only Responses API subset.
CODEXGW_OPENAI_COMPATIBILITY_ENABLED=false
# Private root for single-use inference workspaces (default ~/.codex-gateway-inference).
# Kept separate from CODEX_HOME so the read-only inference cwd never sits beside auth material.
# CODEXGW_INFERENCE_WORKSPACE_ROOT=/absolute/path/to/.codex-gateway-inference

CODEXGW_MAX_QUEUED_JOBS=100
CODEXGW_MAX_CONCURRENT_JOBS=2
CODEXGW_MAX_PROMPT_BYTES=65536
CODEXGW_MAX_RESULT_BYTES=1048576
CODEXGW_MAX_EVENT_BYTES=65536
CODEXGW_MAX_EVENTS_PER_JOB=10000
CODEXGW_RPC_TIMEOUT_MS=30000
CODEXGW_TURN_TIMEOUT_MS=1800000

# Terminal jobs (and conversations with no remaining jobs) older than this
# are deleted by an hourly sweep. The database file does not shrink on disk;
# freed pages are reused.
CODEXGW_RETENTION_DAYS=14
